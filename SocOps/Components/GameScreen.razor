@using SocOps.Models

<div class="retro-game">
    <header class="retro-header">
        <button @onclick="OnReset" class="retro-back" aria-label="Return to start screen">Back</button>
        <h1 class="retro-header-title">SOC OPS GRID</h1>
        <div class="w-16" aria-hidden="true"></div>
    </header>

    <p class="retro-hud">
        Match each card with a real person. Mark squares to complete your line.
    </p>

    @if (HasBingo)
    {
        <div class="retro-status retro-status--bingo">Bingo line confirmed</div>
    }

    <div class="retro-board-wrap">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
