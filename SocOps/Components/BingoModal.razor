<div class="retro-modal fixed inset-0 z-50">
    <div class="retro-modal-card animate-[bounce_0.5s_ease-out]" role="dialog" aria-modal="true" aria-label="Bingo dialog">
        <h2 class="retro-modal-title">Bingo Achieved</h2>
        <p class="retro-modal-copy">You completed a full line.</p>

        <button @onclick="OnDismiss" class="retro-button-secondary">
            Continue Mission
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
