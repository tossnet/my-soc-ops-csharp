<div class="retro-shell">
    <div class="retro-panel" role="region" aria-label="Game start panel">
        <h1 class="retro-title">SOC OPS</h1>
        <p class="retro-subtitle">Social Bingo C64 Edition</p>

        <div class="retro-block">
            <h2>How To Play</h2>
            <ul class="retro-list">
                <li>Find people who match each mission square.</li>
                <li>Tap a square when you verify a match.</li>
                <li>Hit five in a row to trigger BINGO.</li>
            </ul>
        </div>

        <button @onclick="OnStart" class="retro-button">
            Load Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
