@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="retro-square-text wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsFreeSpace)
    {
        <span class="retro-square-chip">FREE</span>
    }
    else if (Square.IsMarked)
    {
        <span class="retro-square-chip">MARKED</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "retro-square transition-all duration-150 select-none";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "retro-square--winning"
                : "retro-square--marked"
            : string.Empty;

        var freeSpaceClasses = Square.IsFreeSpace ? "retro-square--free" : string.Empty;

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
